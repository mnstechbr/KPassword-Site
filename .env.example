# Usado localmente para sincronizar a página Baixar e a página Novidades com os lançamentos do GitHub.
PUBLIC_GITHUB_OWNER=mnstechbr
PUBLIC_GITHUB_REPO=KPassword
KPASSWORD_RELEASE_ASSET_NAME=KPassword-Setup.exe

# GitHub Pages com URL do tipo https://usuario.github.io/KPassword usa /KPassword.
# Site com domínio próprio normalmente usa /.
PUBLIC_SITE_BASE_PATH=/
PUBLIC_SITE_URL=https://kpassword.vercel.app
