---
import { links, product, repo } from '@/data/site';
import { pathTo } from '@/utils/paths';
import { content, getPath, type Locale } from '@/data/i18n';

interface Props {
  locale?: Locale;
}

const locale = Astro.props.locale || 'pt';
const t = content[locale];
---

<footer class="site-footer">
  <div>
    <strong>{product.name}</strong>
    <p>{t.footer.description}</p>
  </div>

  <nav aria-label="rodapé">
    <a href={pathTo(getPath(locale, 'docs'))}>{t.footer.docs}</a>
    <a href={pathTo(getPath(locale, 'securityPolicy'))}>{t.footer.securityPolicy}</a>
    <a href={pathTo(getPath(locale, 'termsPrivacy'))}>{t.footer.termsPrivacy}</a>
    {repo.isConfigured ? <a href={links.repository}>{t.footer.github}</a> : <a href={pathTo(getPath(locale, 'download'))}>{t.footer.github}</a>}
  </nav>
</footer>
