---
import { pathTo } from '@/utils/paths';
import { product } from '@/data/site';
import { content, getPath, locales, pageKeys, type Locale, type PageKey } from '@/data/i18n';

interface Props {
  locale?: Locale;
  pageKey?: PageKey;
}

const locale = Astro.props.locale || 'pt';
const pageKey = Astro.props.pageKey || 'home';
const t = content[locale];

const nav = [
  { key: 'home', label: t.nav.home },
  { key: 'download', label: t.nav.download },
  { key: 'security', label: t.nav.security },
  { key: 'changelog', label: t.nav.changelog }
] as const;

const localeOptions = Object.values(locales).map((item) => {
  const code = item.code as Locale;
  const safePage = pageKeys.includes(pageKey) ? pageKey : 'home';
  return {
    ...item,
    href: pathTo(getPath(code, safePage))
  };
});
---

<header class="site-header">
  <a class="brand" href={pathTo(getPath(locale, 'home'))} aria-label={`${product.name} ${t.nav.home}`}>
    <img class="brand-icon" src={pathTo('/brand/app-icon.png')} alt="" width="34" height="34" />
    <span>{product.name}</span>
  </a>

  <nav class="nav" aria-label={t.nav.home}>
    {nav.map((item) => <a class:list={[item.key === pageKey && 'is-active']} href={pathTo(getPath(locale, item.key))}>{item.label}</a>)}
  </nav>

  <div class="header-actions">
    <div class="language-picker" data-language-picker>
      <button
        class="language-button"
        type="button"
        aria-label={t.language.aria}
        title={t.language.aria}
        aria-haspopup="listbox"
        aria-expanded="false"
        aria-controls={`language-menu-${locale}`}
        data-language-button
      >
        <span class="sr-only">{t.language.label}</span>
        <svg class="language-icon" viewBox="0 0 24 24" aria-hidden="true">
          <circle cx="12" cy="12" r="9"></circle>
          <path d="M3 12h18"></path>
          <path d="M12 3c2.2 2.5 3.3 5.5 3.3 9S14.2 18.5 12 21"></path>
          <path d="M12 3C9.8 5.5 8.7 8.5 8.7 12s1.1 6.5 3.3 9"></path>
        </svg>
      </button>
      <div id={`language-menu-${locale}`} class="language-menu" role="listbox" aria-label={t.language.label} data-language-menu hidden>
        {localeOptions.map((item) => (
          <a
            class:list={['language-option', item.code === locale && 'is-selected']}
            href={item.href}
            role="option"
            aria-selected={item.code === locale ? 'true' : 'false'}
            data-language-option
          >
            {item.label}
          </a>
        ))}
      </div>
    </div>
    <a class="header-cta" href={pathTo(getPath(locale, 'download'))}>{t.header.cta}</a>
  </div>
</header>

<script is:inline>
  document.querySelectorAll('[data-language-picker]').forEach((picker) => {
    const button = picker.querySelector('[data-language-button]');
    const menu = picker.querySelector('[data-language-menu]');
    const options = Array.from(picker.querySelectorAll('[data-language-option]'));

    if (!button || !menu || !options.length) return;

    const focusOption = (index) => {
      const next = options[(index + options.length) % options.length];
      if (next) next.focus();
    };

    const setOpen = (open) => {
      menu.hidden = !open;
      button.setAttribute('aria-expanded', String(open));
      picker.classList.toggle('is-open', open);
    };

    const openAndFocus = () => {
      setOpen(true);
      const selectedIndex = Math.max(0, options.findIndex((option) => option.getAttribute('aria-selected') === 'true'));
      focusOption(selectedIndex);
    };

    button.addEventListener('click', () => {
      if (button.getAttribute('aria-expanded') === 'true') {
        setOpen(false);
      } else {
        openAndFocus();
      }
    });

    button.addEventListener('keydown', (event) => {
      if (event.key === 'ArrowDown' || event.key === 'Enter' || event.key === ' ') {
        event.preventDefault();
        openAndFocus();
      }
    });

    options.forEach((option, index) => {
      option.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
          event.preventDefault();
          setOpen(false);
          button.focus();
        }

        if (event.key === 'ArrowDown') {
          event.preventDefault();
          focusOption(index + 1);
        }

        if (event.key === 'ArrowUp') {
          event.preventDefault();
          focusOption(index - 1);
        }

        if (event.key === 'Home') {
          event.preventDefault();
          focusOption(0);
        }

        if (event.key === 'End') {
          event.preventDefault();
          focusOption(options.length - 1);
        }
      });
    });

    document.addEventListener('click', (event) => {
      if (!(event.target instanceof Node) || !picker.contains(event.target)) {
        setOpen(false);
      }
    });
  });
</script>
