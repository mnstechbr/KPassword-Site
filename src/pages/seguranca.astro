---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import CardGrid from '../components/CardGrid.astro';
import Callout from '../components/Callout.astro';
import { safeguards, securityPillars } from '../data/site';
---
<BaseLayout title="Segurança" description="Conheça o modelo de segurança do KPassword, incluindo Argon2id, AES-256-GCM, AAD, backups criptografados, autolock e updater assinado.">
  <PageHero eyebrow="Modelo de segurança" title="Proteção local, explicada sem truques de palco." text="O KPassword foi desenhado para reduzir riscos em um cofre local/offline. Esta página explica escolhas técnicas, limites e responsabilidades do usuário." />

  <section class="page-section">
    <CardGrid items={securityPillars} />
  </section>

  <section class="page-section two-column">
    <div class="panel">
      <h2>Componentes principais</h2>
      <ul>
        {safeguards.map((item) => <li>{item}</li>)}
      </ul>
    </div>
    <div class="panel">
      <h2>O que isso não significa</h2>
      <p>
        Nenhum gerenciador de senhas consegue eliminar todos os riscos. Malware no computador, senha mestra fraca, perda de backups ou sistema desatualizado podem comprometer a proteção.
      </p>
      <Callout tone="warn">
        <p>Use uma senha mestra longa, mantenha o Windows atualizado e guarde backups em locais confiáveis.</p>
      </Callout>
    </div>
  </section>

  <section class="page-section">
    <div class="section-heading">
      <p class="eyebrow">Arquitetura</p>
      <h2>Como pensar o cofre</h2>
      <p>Uma visão simples do fluxo, da senha mestra até os dados protegidos.</p>
    </div>
    <div class="panel">
      <pre><code>{`Senha mestra do usuário
        ↓
Argon2id gera material de chave
        ↓
AES-256-GCM criptografa e autentica o cofre
        ↓
AAD protege contexto adicional
        ↓
Backups criptografados ajudam na recuperação`}</code></pre>
    </div>
  </section>

  <section class="page-section two-column">
    <div class="panel">
      <h2>Boas práticas para o usuário</h2>
      <ul>
        <li>Crie uma senha mestra longa, única e memorável.</li>
        <li>Não salve a senha mestra em notas soltas ou prints.</li>
        <li>Faça backup criptografado depois de mudanças importantes.</li>
        <li>Não instale versões recebidas por fontes desconhecidas.</li>
        <li>Verifique o hash do instalador quando disponível.</li>
      </ul>
    </div>
    <div class="panel">
      <h2>Transparência</h2>
      <p>
        A documentação deve acompanhar a evolução do app. Quando o formato criptográfico, updater ou políticas de backup mudarem, o changelog deve registrar a mudança com linguagem clara.
      </p>
      <a class="button" href="/politica-de-seguranca/">Ler política de segurança</a>
    </div>
  </section>
</BaseLayout>
