---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { pathTo } from '@/utils/paths';
import { content, getPath } from '@/data/i18n';

const t = content.pt.notFound;
---

<BaseLayout locale="pt" pageKey="home" title={t.metaTitle}>
  <section class="not-found">
    <p class="label">{t.label}</p>
    <h1>{t.title}</h1>
    <p>{t.text}</p>
    <a class="button primary" href={pathTo(getPath('pt', 'home'))}>{t.button}</a>
  </section>
</BaseLayout>
