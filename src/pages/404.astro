---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Página não encontrada" description="A página solicitada não foi encontrada no site do KPassword.">
  <section class="page-hero">
    <p class="eyebrow">404</p>
    <h1>Essa porta não abre este cofre.</h1>
    <p class="lead">A página não foi encontrada. Volte para a Home ou siga para o Download.</p>
    <div class="action-row">
      <a class="button button-primary" href="/">Voltar para Home</a>
      <a class="button" href="/download/">Ir para Download</a>
    </div>
  </section>
</BaseLayout>
