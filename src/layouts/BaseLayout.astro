---
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { pathTo } from '@/utils/paths';
import { product } from '@/data/site';
import { content, getPath, locales, type Locale, type PageKey } from '@/data/i18n';
import '@/styles/global.css';

interface Props {
  title?: string;
  description?: string;
  locale?: Locale;
  pageKey?: PageKey;
}

const locale = Astro.props.locale || 'pt';
const pageKey = Astro.props.pageKey || 'home';
const t = content[locale];
const title = Astro.props.title ? `${Astro.props.title} · ${product.name}` : `${product.name} · ${t.siteTitleSuffix}`;
const description = Astro.props.description || t.siteDescription;
const htmlLang = locales[locale].htmlLang;
const siteOrigin = (Astro.site?.toString() || 'https://kpassword.vercel.app').replace(/\/$/, '');
const ogImage = new URL(pathTo('/brand/app-icon.png'), `${siteOrigin}/`).toString();
const alternateLocales = Object.values(locales).map((item) => ({
  htmlLang: item.htmlLang,
  href: pathTo(getPath(item.code as Locale, pageKey))
}));
---

<!doctype html>
<html lang={htmlLang} data-locale={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#090b12" />
    <title>{title}</title>
    <link rel="icon" href={pathTo('/favicon.ico')} sizes="any" />
    <link rel="icon" type="image/png" href={pathTo('/favicon.png')} />
    <link rel="icon" type="image/svg+xml" href={pathTo('/favicon.svg')} />
    <link rel="apple-touch-icon" href={pathTo('/brand/app-icon.png')} />
    {alternateLocales.map((item) => <link rel="alternate" hreflang={item.htmlLang} href={item.href} />)}
    <link rel="alternate" hreflang="x-default" href={pathTo(getPath('pt', pageKey))} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImage} />
  </head>
  <body>
    <div class="grain"></div>
    <Header locale={locale} pageKey={pageKey} />
    <main>
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
